{
  "name": "@looper/looperd",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "bun run scripts/generate-artifacts.ts",
    "dev": "bun run codegen && bun run src/index.ts",
    "build": "bun run codegen && bun build src/compiled.ts --outfile dist/index.js --target bun",
    "compile": "bun run scripts/compile.ts all",
    "compile:darwin-arm64": "bun run scripts/compile.ts darwin-arm64",
    "compile:darwin-x64": "bun run scripts/compile.ts darwin-x64",
    "typecheck": "bun x tsc -p tsconfig.json --noEmit"
  }
}
