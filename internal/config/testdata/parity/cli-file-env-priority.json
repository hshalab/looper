{
  "description": "merges config file, env, and CLI overrides into the frozen compatibility surface",
  "input": {
    "argv": [
      "--config",
      "configs/priority.json",
      "--port",
      "7000",
      "--git-path",
      "/cli/git",
      "--allow-auto-commit",
      "false",
      "--allow-auto-push",
      "false",
      "--osascript-path",
      "/cli/osascript"
    ],
    "env": {
      "LOOPER_HOST": "127.0.0.2",
      "LOOPER_DB_PATH": "__TMP__/env.sqlite",
      "LOOPER_LOG_DIR": "__TMP__/env-logs",
      "LOOPER_OSASCRIPT_ENABLED": "false",
      "LOOPER_IN_APP_NOTIFICATIONS": "false",
      "LOOPER_GH_PATH": "/env/gh",
      "LOOPER_ALLOW_AUTO_COMMIT": "true",
      "LOOPER_ALLOW_AUTO_APPROVE": "true"
    },
    "files": {
      "configs/priority.json": {
        "server": {
          "host": "0.0.0.0",
          "port": 5555
        },
        "daemon": {
          "logDir": "__TMP__/file-logs",
          "workingDirectory": "__TMP__/workspace",
          "environment": {
            "FROM_FILE": "1"
          }
        },
        "storage": {
          "dbPath": "__TMP__/file.sqlite"
        },
        "notifications": {
          "osascript": {
            "enabled": true,
            "throttleWindowSeconds": 60
          }
        },
        "tools": {
          "gitPath": "/file/git",
          "ghPath": "/file/gh"
        },
        "defaults": {
          "allowAutoCommit": false,
          "baseBranch": "develop"
        },
        "agent": {
          "vendor": "opencode",
          "params": {
            "tier": "file"
          },
          "env": {
            "FILE_ENV": "file"
          },
          "timeouts": {
            "workerSeconds": 2400
          }
        },
        "projects": [
