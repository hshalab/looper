# looper HITL — Feishu transport environment variables.
#
# The Feishu app and the Cloudflare inbox worker are SHARED across the team, so
# these values are the SAME for everyone. The workflow:
#   1. One person fills this in with the real shared values.
#   2. Distribute the filled file privately (NOT via git — it holds secrets).
#   3. Each teammate saves it and sources it before running looperd.
#
# Per-person settings (which group, who to @) are NOT here — they go in each
# teammate's own config file (notifications.webhook.chatId / mentionOpenIds).
#
# Usage:
#   cp deploy/hitl.env.example ~/.looper/hitl.env     # then fill in the values
#   source ~/.looper/hitl.env                          # export into the shell
#   looperd --config ~/.looper/config.json
#
# Or, for the managed daemon, point a launchd/systemd EnvironmentFile at the
# filled file so the vars are present whenever looperd starts.

# --- Feishu custom app (shared) ---
export LOOPER_FEISHU_APP_ID=cli_xxxxxxxxxxxx
export LOOPER_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
export LOOPER_FEISHU_VERIFY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx   # app Event Subscription verification token

# --- Cloudflare inbox worker (shared) ---
export LOOPER_FEISHU_INBOX_URL=https://looper-feishu.example.workers.dev/events
export LOOPER_FEISHU_INBOX_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx    # = the worker's POLL_TOKEN secret

# --- Optional: live tool-call feed inside the thread (codex --json) ---
export LOOPER_CODEX_JSON_EVENTS=1
